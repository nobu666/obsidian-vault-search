#!/usr/bin/env python3
"""vault-search — hybrid (keyword + embedding) search over an Obsidian/Markdown vault.

Fully local: embeddings come from Ollama over HTTP, the index is plain SQLite.
With the default localhost Ollama, note contents never leave the machine.

Usage:
  vault-search index [--rebuild]       update the index (incremental; --rebuild wipes first)
  vault-search "natural language query" [-k N]   hybrid search (default top-8)
  vault-search selfcheck               run internal tests (no Ollama needed)

Environment overrides:
  VAULT_DIR             default ~/Documents/Obsidian/Vault
  VAULT_SEARCH_DB       default ~/.cache/vault-search/index.db
  VAULT_SEARCH_MODEL    default bge-m3
  OLLAMA_HOST           default http://localhost:11434
  VAULT_SEARCH_EXCLUDE  extra directory names to skip while indexing,
                        comma-separated (e.g. "News,Attachments"); matched by
                        name at any depth, added to the built-in excludes
"""
import os, sys, re, json, math, sqlite3, time, urllib.request, urllib.error
from array import array
from pathlib import Path
from collections import defaultdict

VAULT = Path(os.environ.get("VAULT_DIR", Path.home() / "Documents/Obsidian/Vault"))
DB_PATH = Path(os.environ.get("VAULT_SEARCH_DB", Path.home() / ".cache/vault-search/index.db"))
OLLAMA = os.environ.get("OLLAMA_HOST", "http://localhost:11434")
MODEL = os.environ.get("VAULT_SEARCH_MODEL", "bge-m3")
def _parse_exclude(raw):
    """Comma-separated dir names -> set (blanks dropped, whitespace stripped)."""
    return {d.strip() for d in raw.split(",") if d.strip()}


EXCLUDE_DIRS = {".obsidian", ".trash", ".git"} | _parse_exclude(
    os.environ.get("VAULT_SEARCH_EXCLUDE", ""))
MAX_CHUNK = 1500   # characters; sections longer than this are split on paragraphs
EMBED_BATCH = 32
RRF_K = 60
# How many top hits anchor the 1-hop neighbor expansion (link/tag), and how
# strongly we boost neighbor chunks. Boost is a fraction of one RRF "slot" so
# anchors stay on top — neighbors only break ties or lift near-miss candidates.
NEIGHBOR_ANCHORS = 10
NEIGHBOR_BOOST = 0.5 / (RRF_K + 1)  # ~half of a top-1 RRF slot
# A file picks up neighbor boost from any anchor whose tag-overlap >= this fraction
# of the anchor's tags. 1.0 = all-tags-match (strict). Avoids "common tag" floods.
TAG_OVERLAP_MIN = 0.5
LOG_ENABLED = os.environ.get("VAULT_SEARCH_NO_LOG", "").strip().lower() not in ("1", "true", "yes", "on")

# Codepoint ranges stripped from displayed snippets. Notes may hold untrusted
# content (web clippings, etc.) and snippets print to a terminal and/or feed an
# AI agent, so drop C0 controls + DEL (ANSI escapes) and zero-width / bidi-override
# formatting that could spoof the displayed text. (Tab/LF/CR are left to \s+.)
_STRIP_RANGES = (
    (0x00, 0x08), (0x0b, 0x0c), (0x0e, 0x1f), (0x7f, 0x7f),
    (0x200b, 0x200f), (0x202a, 0x202e), (0x2066, 0x2069),
)


def die(msg):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


# ---------- embedding (Ollama) ----------
def embed(texts):
    """texts: list[str] -> list[list[float]]"""
    out = []
    for i in range(0, len(texts), EMBED_BATCH):
        batch = texts[i:i + EMBED_BATCH]
        req = urllib.request.Request(
            f"{OLLAMA}/api/embed",
            data=json.dumps({"model": MODEL, "input": batch}).encode(),
            headers={"Content-Type": "application/json"},
        )
        try:
            with urllib.request.urlopen(req, timeout=300) as r:
                data = json.load(r)
        except urllib.error.URLError as e:
            die(f"cannot reach Ollama ({OLLAMA}); is `ollama serve` running? {e}")
        embs = data.get("embeddings")
        if not embs:
            die(f"no embeddings returned; is the model present? `ollama pull {MODEL}` (response: {data})")
        out.extend(embs)
    return out


def normalize(vec):
    n = math.sqrt(sum(x * x for x in vec)) or 1.0
    return [x / n for x in vec]


# ---------- link / tag extraction ----------
# Wikilinks `[[Target]]` / `[[Target|alias]]` / `[[Target#heading]]`. We keep the
# bare target (no alias, no subpath) and normalize: lowercase, strip leading
# folder components — names collide rarely enough in a personal vault and the
# boost is broad anyway, exact resolution isn't worth the complexity.
_WIKILINK_RE = re.compile(r"\[\[([^\[\]|#]+?)(?:#[^\[\]|]*)?(?:\|[^\[\]]*)?\]\]")
# Inline `#tag` (Obsidian style, allowing `/` for nested). Avoid matching `#` in
# Markdown headings (line-start `#` followed by space) and URLs (` #frag` after non-space).
_INLINE_TAG_RE = re.compile(r"(?:^|[\s(\[])#([\w/-]+)", re.MULTILINE)
# YAML frontmatter at the top: `---\n...\n---`. We pull `tags: ...` from it
# (both inline list form and YAML block list form).
_FRONTMATTER_RE = re.compile(r"\A---\n(.*?)\n---\s*\n", re.DOTALL)


def _basename(name):
    """Normalize a wikilink target or file path stem for comparison."""
    n = Path(name).name.lower()
    return n[:-3] if n.endswith(".md") else n  # str.removesuffix is 3.9+; keep 3.8 compat


def _frontmatter_tags(fm_body):
    """Pull `tags:` (inline `[a, b]` or YAML block list) from frontmatter body. Lowercased."""
    out = set()
    lines = fm_body.split("\n")
    i = 0
    while i < len(lines):
        line = lines[i]
        stripped = line.strip()
        if stripped.lower().startswith("tags:"):
            rest = stripped.split(":", 1)[1].strip()
            if rest.startswith("[") and rest.endswith("]"):
                for t in rest[1:-1].split(","):
                    t = t.strip().strip("\"'").lstrip("#").lower()
                    if t:
                        out.add(t)
            elif not rest:  # YAML block list on following indented `- item` lines
                j = i + 1
                while j < len(lines) and re.match(r"^\s+-\s", lines[j]):
                    t = lines[j].split("-", 1)[1].strip().strip("\"'").lstrip("#").lower()
                    if t:
                        out.add(t)
                    j += 1
                i = j - 1
        i += 1
    return out


def extract_links_tags(text):
    """-> (set[str] wikilink targets normalized, set[str] tags lowercased)"""
    links = {_basename(m.group(1).strip()) for m in _WIKILINK_RE.finditer(text) if m.group(1).strip()}
    tags = {t.lower() for t in _INLINE_TAG_RE.findall(text)}
    m = _FRONTMATTER_RE.match(text)
    if m:
        tags |= _frontmatter_tags(m.group(1))
    return links, tags


# ---------- chunking ----------
def chunk_file(path):
    """-> list[(line_no, text)]  one chunk per heading; long sections split on paragraphs."""
    text = path.read_text(encoding="utf-8", errors="replace")
    lines = text.split("\n")
    sections, cur_start, cur = [], 0, []
    for idx, ln in enumerate(lines):
        if re.match(r"^#{1,6}\s", ln) and cur:
            sections.append((cur_start, cur))
            cur_start, cur = idx, [ln]
        else:
            if not cur:
                cur_start = idx
            cur.append(ln)
    if cur:
        sections.append((cur_start, cur))

    chunks = []
    for start, sec_lines in sections:
        body = "\n".join(sec_lines).strip()
        if not body:
            continue
        if len(body) <= MAX_CHUNK:
            chunks.append((start + 1, body))
            continue
        # Split long sections on paragraphs. Sub-chunk line numbers are approximated
        # at the section start (exact per-sub-chunk tracking isn't worth the complexity).
        buf = ""
        for p in re.split(r"\n\s*\n", body):
            if buf and len(buf) + len(p) > MAX_CHUNK:
                chunks.append((start + 1, buf.strip()))
                buf = p
            else:
                buf = (buf + "\n\n" + p) if buf else p
        if buf.strip():
            chunks.append((start + 1, buf.strip()))
    return chunks


# ---------- db ----------
def db_connect():
    DB_PATH.parent.mkdir(parents=True, exist_ok=True)
    con = sqlite3.connect(DB_PATH)
    # The DB now stores the query log (raw query strings). Tighten perms to 0600
    # so a stray secret in a query isn't world-readable on shared systems. Best-effort.
    try:
        os.chmod(DB_PATH, 0o600)
    except OSError:
        pass
    con.execute("CREATE TABLE IF NOT EXISTS files(path TEXT PRIMARY KEY, mtime REAL)")
    con.execute("CREATE TABLE IF NOT EXISTS chunks("
                "id INTEGER PRIMARY KEY, path TEXT, line INTEGER, text TEXT, vec BLOB)")
    con.execute("CREATE INDEX IF NOT EXISTS idx_chunks_path ON chunks(path)")
    # 1-hop neighbor structure: wikilink targets (basename-normalized) and tags per file.
    con.execute("CREATE TABLE IF NOT EXISTS file_links(path TEXT, target TEXT)")
    con.execute("CREATE INDEX IF NOT EXISTS idx_links_path ON file_links(path)")
    con.execute("CREATE INDEX IF NOT EXISTS idx_links_target ON file_links(target)")
    con.execute("CREATE TABLE IF NOT EXISTS file_tags(path TEXT, tag TEXT)")
    con.execute("CREATE INDEX IF NOT EXISTS idx_tags_path ON file_tags(path)")
    con.execute("CREATE INDEX IF NOT EXISTS idx_tags_tag ON file_tags(tag)")
    # Query log — write-only here; consumed later when ④ (memory axis) is built.
    con.execute("CREATE TABLE IF NOT EXISTS query_log("
                "id INTEGER PRIMARY KEY, ts REAL, query TEXT, returned_paths TEXT)")
    return con


def iter_md():
    for root, dirs, files in os.walk(VAULT):
        dirs[:] = [d for d in dirs if d not in EXCLUDE_DIRS]
        for f in files:
            if f.endswith(".md"):
                yield Path(root) / f


def cmd_index(rebuild=False):
    if not VAULT.is_dir():
        die(f"vault not found: {VAULT}")
    con = db_connect()
    if rebuild:
        con.execute("DELETE FROM files")
        con.execute("DELETE FROM chunks")
        con.commit()
    stored = dict(con.execute("SELECT path, mtime FROM files").fetchall())
    seen, changed, new_chunks = set(), 0, 0
    for path in iter_md():
        sp = str(path)
        seen.add(sp)
        mt = path.stat().st_mtime
        if stored.get(sp) == mt:
            continue
        chunks = chunk_file(path)
        full_text = path.read_text(encoding="utf-8", errors="replace")
        links, tags = extract_links_tags(full_text)
        con.execute("DELETE FROM chunks WHERE path=?", (sp,))
        con.execute("DELETE FROM file_links WHERE path=?", (sp,))
        con.execute("DELETE FROM file_tags WHERE path=?", (sp,))
        if chunks:
            vecs = embed([c[1] for c in chunks])
            if len(vecs) != len(chunks):  # a mismatch would let zip() silently drop chunks
                die(f"embedding count != chunk count ({len(vecs)}!={len(chunks)}); check Ollama response")
            for (line, txt), v in zip(chunks, vecs):
                blob = array("f", normalize(v)).tobytes()
                con.execute("INSERT INTO chunks(path, line, text, vec) VALUES(?,?,?,?)",
                            (sp, line, txt, blob))
            new_chunks += len(chunks)
        con.executemany("INSERT INTO file_links(path, target) VALUES(?,?)", [(sp, t) for t in links])
        con.executemany("INSERT INTO file_tags(path, tag) VALUES(?,?)", [(sp, t) for t in tags])
        con.execute("INSERT OR REPLACE INTO files(path, mtime) VALUES(?,?)", (sp, mt))
        changed += 1
        con.commit()
    removed = 0
    for sp in stored:
        if sp not in seen:
            con.execute("DELETE FROM chunks WHERE path=?", (sp,))
            con.execute("DELETE FROM file_links WHERE path=?", (sp,))
            con.execute("DELETE FROM file_tags WHERE path=?", (sp,))
            con.execute("DELETE FROM files WHERE path=?", (sp,))
            removed += 1
    con.commit()
    total = con.execute("SELECT COUNT(*) FROM chunks").fetchone()[0]
    print(f"index: {changed} files updated (+{new_chunks} chunks), {removed} removed. total chunks={total}")


# ---------- search ----------
def cosine_topn(qn, topn):
    """qn: normalized query vector -> [(score, cid)] top-n"""
    con = db_connect()
    qd = len(qn)
    scored = []
    for cid, blob in con.execute("SELECT id, vec FROM chunks"):
        v = array("f")
        v.frombytes(blob)
        if len(v) != qd:  # if the model changed, zip() would silently miscompute; stop explicitly
            die(f"vector dimension mismatch (query={qd}, index={len(v)}); "
                f"if you switched models, run `vault-search index --rebuild`")
        # both v and qn are normalized -> dot == cosine.
        # Brute-force pure-python scan (~75ms for ~3k chunks; plenty for recall).
        scored.append((sum(a * b for a, b in zip(qn, v)), cid))
    scored.sort(reverse=True)
    return scored[:topn]


def keyword_hits(query):
    """Substring-match indexed chunk text directly. No external rg. -> dict[cid] = matched terms"""
    terms = [t.lower() for t in re.split(r"\s+", query.strip()) if len(t) >= 2] \
        or [query.strip().lower()]
    con = db_connect()
    score = {}
    for cid, txt in con.execute("SELECT id, text FROM chunks"):
        low = txt.lower()
        c = sum(1 for t in terms if t in low)
        if c:
            score[cid] = c
    return score


def make_snippet(txt, n=140):
    s = "".join(c for c in txt if not any(lo <= ord(c) <= hi for lo, hi in _STRIP_RANGES))
    s = re.sub(r"\s+", " ", s).strip()
    s = re.sub(r"^#{1,6}\s*", "", s)
    return s[:n] + ("…" if len(s) > n else "")


def _neighbor_paths(con, anchor_paths):
    """1-hop neighbors of anchor_paths: link targets, files that link to anchors,
    and files that share >= TAG_OVERLAP_MIN of an anchor's tags. -> set[str]."""
    if not anchor_paths:
        return set()
    anchors = list(anchor_paths)
    placeholders = ",".join("?" * len(anchors))
    neighbors = set()

    # anchor -> its link targets -> resolve back to files whose basename matches
    targets = {t for (t,) in con.execute(
        f"SELECT DISTINCT target FROM file_links WHERE path IN ({placeholders})", anchors)}
    if targets:
        tph = ",".join("?" * len(targets))
        for (p,) in con.execute(f"SELECT path FROM files"):
            if _basename(p) in targets:
                neighbors.add(p)

    # files that link TO any anchor (backlinks). Anchor basenames -> file_links.target
    anchor_bases = {_basename(p) for p in anchors}
    if anchor_bases:
        abph = ",".join("?" * len(anchor_bases))
        for (p,) in con.execute(
            f"SELECT DISTINCT path FROM file_links WHERE target IN ({abph})",
            list(anchor_bases),
        ):
            neighbors.add(p)

    # tag overlap: any file sharing >= TAG_OVERLAP_MIN fraction of an anchor's tags
    anchor_tags = defaultdict(set)
    for p, t in con.execute(
        f"SELECT path, tag FROM file_tags WHERE path IN ({placeholders})", anchors,
    ):
        anchor_tags[p].add(t)
    if anchor_tags:
        # candidate files: any file sharing at least one tag with any anchor
        all_tags = set().union(*anchor_tags.values())
        if all_tags:
            tagph = ",".join("?" * len(all_tags))
            cand = defaultdict(set)
            for p, t in con.execute(
                f"SELECT path, tag FROM file_tags WHERE tag IN ({tagph})", list(all_tags),
            ):
                cand[p].add(t)
            for cp, ct in cand.items():
                for ap, at in anchor_tags.items():
                    if cp == ap or not at:
                        continue
                    if len(ct & at) / len(at) >= TAG_OVERLAP_MIN:
                        neighbors.add(cp)
                        break

    neighbors -= set(anchors)  # don't double-boost anchors themselves
    return neighbors


def _log_query(con, query, returned_paths):
    if not LOG_ENABLED:
        return
    try:
        con.execute(
            "INSERT INTO query_log(ts, query, returned_paths) VALUES(?,?,?)",
            (time.time(), query, "\n".join(returned_paths)),
        )
        con.commit()
    except sqlite3.Error:
        pass  # logging is best-effort; never break a search on it


def cmd_search(query, k):
    con = db_connect()
    if con.execute("SELECT COUNT(*) FROM chunks").fetchone()[0] == 0:
        die("index is empty; run `vault-search index` first")

    qn = normalize(embed([query])[0])
    emb = cosine_topn(qn, 50)
    emb_rank = {cid: r for r, (_, cid) in enumerate(emb, 1)}

    kw_score = keyword_hits(query)
    kw_rank = {cid: r for r, (cid, _) in
               enumerate(sorted(kw_score.items(), key=lambda x: -x[1]), 1)}

    # Reciprocal Rank Fusion
    rrf = defaultdict(float)
    for cid, r in emb_rank.items():
        rrf[cid] += 1.0 / (RRF_K + r)
    for cid, r in kw_rank.items():
        rrf[cid] += 1.0 / (RRF_K + r)

    # 1-hop neighbor boost: top anchors' linked/backlinked/tag-overlap files
    # each get a fixed small bump on every chunk they own. Tie-breaks + near-miss
    # lifts only — the boost is < one top-1 RRF slot so anchors stay on top.
    pre_top = sorted(rrf.items(), key=lambda x: -x[1])[:NEIGHBOR_ANCHORS]
    anchor_paths = set()
    nb_neighbors = set()
    if pre_top:
        pre_ids = [cid for cid, _ in pre_top]
        anchor_paths = {p for (p,) in con.execute(
            f"SELECT DISTINCT path FROM chunks WHERE id IN ({','.join('?' * len(pre_ids))})",
            pre_ids,
        )}
        nb_neighbors = _neighbor_paths(con, anchor_paths)
        if nb_neighbors:
            placeholders = ",".join("?" * len(nb_neighbors))
            for (cid,) in con.execute(
                f"SELECT id FROM chunks WHERE path IN ({placeholders})", list(nb_neighbors),
            ):
                rrf[cid] += NEIGHBOR_BOOST

    ranked = sorted(rrf.items(), key=lambda x: -x[1])[:k]

    if not ranked:
        print("(no hits)")
        _log_query(con, query, [])
        return
    returned_paths = []
    for cid, _ in ranked:
        p, ln, txt = con.execute("SELECT path, line, text FROM chunks WHERE id=?", (cid,)).fetchone()
        rel = os.path.relpath(p, VAULT)
        tags = []
        if cid in emb_rank:
            tags.append("emb")
        if cid in kw_rank:
            tags.append("kw")
        if p in nb_neighbors:
            tags.append("nb")
        print(f"{rel}:{ln}  [{'+'.join(tags)}]  {make_snippet(txt)}")
        returned_paths.append(rel)
    _log_query(con, query, returned_paths)


def cmd_selfcheck():
    """Verify core logic (cosine / chunking / RRF / snippet) without Ollama or the DB."""
    import tempfile
    # cosine: identical vectors -> 1, orthogonal -> 0
    a, b = normalize([1.0, 2.0, 3.0]), normalize([1.0, 2.0, 3.0])
    assert abs(sum(x * y for x, y in zip(a, b)) - 1.0) < 1e-6, "cosine identical"
    o1, o2 = normalize([1.0, 0.0]), normalize([0.0, 1.0])
    assert abs(sum(x * y for x, y in zip(o1, o2))) < 1e-6, "cosine orthogonal"
    # chunking: heading split and long-section paragraph split
    with tempfile.NamedTemporaryFile("w", suffix=".md", delete=False, encoding="utf-8") as f:
        f.write("# A\nalpha\n\n## B\nbeta\n\n## C\n" + "x " * 2000)
        tmp = f.name
    try:
        chunks = chunk_file(Path(tmp))
    finally:
        os.unlink(tmp)
    assert len(chunks) >= 3, f"chunking sections={len(chunks)}"
    assert chunks[0][0] == 1, "first chunk starts at line 1"
    # snippet: control chars / bidi overrides are stripped
    bad = "alpha\x1b[31mRED\x1b[0m" + chr(0x202e) + "beta"
    snip = make_snippet(bad)
    assert "\x1b" not in snip and chr(0x202e) not in snip and "alpha" in snip, "snippet sanitize"
    # RRF: an item present in both lists ranks on top
    emb, kw = {1: 1, 2: 2, 3: 3}, {3: 1, 4: 2}
    rrf = defaultdict(float)
    for cid, r in emb.items():
        rrf[cid] += 1.0 / (RRF_K + r)
    for cid, r in kw.items():
        rrf[cid] += 1.0 / (RRF_K + r)
    assert max(rrf, key=rrf.get) == 3, "RRF fuses overlap to top"
    # link / tag extraction: wikilinks (with alias/subpath), inline #tag, frontmatter tags
    text = ("---\ntags: [foo, bar]\nrelated:\n  - X\n---\n"
            "# T\nsee [[Other|alias]] and [[Sub#heading]] and #baz here.\n")
    links, tags = extract_links_tags(text)
    assert links == {"other", "sub"}, f"wikilinks: {links}"
    assert tags == {"foo", "bar", "baz"}, f"tags: {tags}"
    # frontmatter YAML block list form
    _, tags2 = extract_links_tags("---\ntags:\n  - one\n  - two\n---\n# T\n")
    assert tags2 == {"one", "two"}, f"yaml block tags: {tags2}"
    # neighbor boost must be smaller than one top-1 RRF slot (so anchors keep priority)
    assert NEIGHBOR_BOOST < 1.0 / (RRF_K + 1), "neighbor boost should be < a top-1 RRF slot"
    print("selfcheck: ok")


def main():
    a = sys.argv[1:]
    if not a or a[0] in ("-h", "--help"):
        print(__doc__)
        return
    if a[0] == "index":
        cmd_index(rebuild=("--rebuild" in a))
        return
    if a[0] == "selfcheck":
        cmd_selfcheck()
        return
    k = 8
    if "-k" in a:
        i = a.index("-k")
        try:
            k = int(a[i + 1])
        except (IndexError, ValueError):
            die("-k requires a number")
        a = a[:i] + a[i + 2:]
    query = " ".join(a).strip()
    if not query:
        die("empty query")
    cmd_search(query, k)


if __name__ == "__main__":
    main()
